{
    "name": "churchcms/church-cms",
    "description": "Open source church management system built with Laravel and Vue.",
    "keywords": [
        "church",
        "church-management",
        "cms",
        "laravel",
        "ministry"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^7.3|^7.4",

        "artesaos/seotools": "^0.19.1",
        "barryvdh/laravel-dompdf": "^0.9.0",
        "botman/botman": "^2.6",
        "botman/driver-web": "^1.5",
        "brozot/laravel-fcm": "*",
        "cyber-duck/laravel-excel": "^2.1",
        "fideloper/proxy": "^4.0",

        "google/cloud": "^0.139.0",
        "google/cloud-language": "^0.24.0",
        "jdavidbakr/mail-tracker": "^3.0",

        "laracasts/presenter": "0.2.*",
        "laravel-frontend-presets/tailwindcss": "^4.2.0",
        "laravel/framework": "^7.4.0",

        "laravel/sanctum": "^2.8",
        "laravel/tinker": "^2.0",
        "lcobucci/jwt": "3.3.3",
        "league/csv": "^9.2",
        "league/flysystem-aws-s3-v3": "^1.0",
        "maatwebsite/excel": "^3.1",
        "nckg/laravel-impersonate": "^3.0",
        "santigarcor/laratrust": "5.2.*",
        "spatie/laravel-activitylog": "^3.6",
        "spatie/laravel-analytics": "^3.10",
        "spatie/laravel-medialibrary": "^7.19",
        "spatie/laravel-sitemap": "^5.8",
        "stevebauman/purify": "^4.0",
        "tijsverkoyen/css-to-inline-styles": "^2.2",
        "titasgailius/search-relations": "^1.0",
        "twilio/sdk": "^6.9"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.2",
        "beyondcode/laravel-dump-server": "^1.4.0",
        "filp/whoops": "^2.4.1",
        "fzaninotto/faker": "^1.4",
        "laravel/dusk": "^5.5",
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^4.1",
        "phpspec/phpspec": "^6.2.1",
        "phpunit/phpunit": "^8.2"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "config/church-cms.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "repositories": [

        {
            "type": "path",
            "url": "./custompackages/brozot/laravel-fcm"
        }




    ],
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
