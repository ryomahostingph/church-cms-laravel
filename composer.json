{
    "name": "churchcms/church-cms",
    "description": "Open source church management system built with Laravel and Vue.",
    "keywords": [
        "church",
        "church-management",
        "cms",
        "laravel",
        "ministry"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^2.2",
        "botman/botman": "^2.6",
        "botman/driver-web": "^1.5",
        "brozot/laravel-fcm": "^1.0",
        "google/cloud-language": "^0.31",
        "google/cloud-storage": "^1.42",
        "guzzlehttp/guzzle": "^7.4",
        "laracasts/presenter": "0.2.*",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.0",
        "laravel/tinker": "^2.10",
        "laravel/ui": "^4.5",
        "lcobucci/jwt": "^4.2",
        "league/csv": "^9.2",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "nckg/laravel-impersonate": "^4.0",
        "santigarcor/laratrust": "^7.2",
        "spatie/laravel-activitylog": "^4.2",
        "spatie/laravel-medialibrary": "^10.0",
        "spatie/laravel-sitemap": "^6.0",
        "tijsverkoyen/css-to-inline-styles": "^2.2",
        "titasgailius/search-relations": "^1.0",
        "twilio/sdk": "^6.9"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.9",
        "fakerphp/faker": "^1.21",
        "filp/whoops": "^2.14",
        "laravel/dusk": "^7.0",
        "laravel/legacy-factories": "^1.4",
        "mockery/mockery": "^1.5",
        "nunomaduro/collision": "^6.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "classmap": [
            "database/seeds"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        },
        "files": [
            "config/church-cms.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "repositories": [

        {
            "type": "path",
            "url": "./custompackages/brozot/laravel-fcm"
        }




    ],
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]
    },
    "config": {
        "audit": {
            "block-insecure": false
        },
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
